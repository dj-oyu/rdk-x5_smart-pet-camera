[Unit]
Description=Comic JPEG sync to AI Pyramid Pro
After=pet-camera-streaming.service
After=network-online.target tailscaled.service
Wants=network-online.target
PartOf=pet-camera.target

[Service]
Type=simple
WorkingDirectory=/opt/smart-pet-camera
EnvironmentFile=-/opt/smart-pet-camera/.env
ExecStart=/opt/smart-pet-camera/scripts/sync-comics.sh
Restart=always
RestartSec=5

[Install]
WantedBy=pet-camera.target
