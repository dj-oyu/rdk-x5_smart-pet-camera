# Smart Pet Camera — Environment Configuration
# Copy to .env and fill in your values:  cp .env.sample .env
#
# This file is used by both devices:
#   rdk-x5:      /app/smart-pet-camera/.env
#   ai-pyramid:  /app/smart-pet-camera/src/ai-pyramid/.env

# ── Device Discovery ─────────────────────────────────────────
# Hostnames (scheme is always HTTPS)
# PET_CAMERA_HOST=your-camera-host.your-tenant.ts.net
# PET_ALBUM_HOST=your-album-host.your-tenant.ts.net

# ── Pet Camera (rdk-x5) ──────────────────────────────────────
# TLS certificates (Tailscale: sudo tailscale cert <hostname>)
# PET_CAMERA_TLS_CERT=/path/to/camera-host.crt
# PET_CAMERA_TLS_KEY=/path/to/camera-host.key

# Web monitor (pet-camera-monitor)
# PET_CAMERA_PORT=8080
# PET_CAMERA_MONITOR_HOST=0.0.0.0
# PET_CAMERA_HTTP_ONLY_PORT=8082
# PET_CAMERA_JPEG_QUALITY=65
# PET_CAMERA_DETECT_PORT=8083

# Streaming server (pet-camera-streaming)
# PET_CAMERA_STREAMING_PORT=8081
# PET_CAMERA_STREAMING_HOST=0.0.0.0
# PET_CAMERA_STREAMING_SHM=/pet_camera_h265_zc
# PET_CAMERA_MAX_CLIENTS=10
# PET_CAMERA_METRICS_PORT=9090
# PET_CAMERA_PPROF_PORT=6060

# Log level: debug / info / warn / error (shared across services)
# PET_CAMERA_LOG_LEVEL=info

# YOLO detector (pet-camera-detector)
# PET_CAMERA_YOLO_MODEL=v11n
# PET_CAMERA_YOLO_SCORE_THRESHOLD=0.6
# PET_CAMERA_YOLO_NMS_THRESHOLD=0.7

# Night frame collection (detector saves NV12 frames here for fine-tuning)
# Falls back to /tmp/night_collect when SSD is not mounted.
# NIGHT_COLLECT_DIR=/tmp/night_collect

# Recording output (comics, H.265 recordings)
# RECORDING_PATH=/mnt/petcam-data/recordings

# ── YOLO NPU Daemon (ai-pyramid) ─────────────────────────────
# Socket path shared between ax_yolo_daemon and pet-album
# AX_YOLO_DAEMON_SOCKET=/run/ax_yolo_daemon.sock

# Model directory for ax_yolo_daemon name resolution
# AX_YOLO_MODEL_DIR=/path/to/models

# 2-model detection pipeline (pet-album Level2 detect)
# Fast model: aspect ratio probing (empty = skip phase 1)
# YOLO_FAST_MODEL=yolo11s
# Accurate model: final detection (empty = skip phase 2)
# YOLO_ACCURATE_MODEL=yolo26l

# ── Pet Album (ai-pyramid) ───────────────────────────────────
# TLS certificates for album server
# PET_ALBUM_TLS_CERT=/path/to/album-host.crt
# PET_ALBUM_TLS_KEY=/path/to/album-host.key

# Remote photos directory for rsync (default shown)
# PET_ALBUM_PHOTOS_DIR=/app/smart-pet-camera/src/ai-pyramid/data/photos

# VLM (axllm) endpoint
# PET_ALBUM_VLM_URL=http://localhost:8000
# PET_ALBUM_VLM_MODEL=AXERA-TECH/Qwen3-VL-2B-Instruct-GPTQ-Int4-C256-P3584-CTX4095

# ── Training annotation (ai-pyramid) ─────────────────────────
# SSH identity file used by pet-album (runs as root) to reach rdk-x5.
# TRAINING_SSH_KEY=/path/to/ssh/key

# Remote directory to rsync NV12 frames from (on rdk-x5).
# Falls back to /tmp/night_collect/feeding when SSD is not mounted.
# TRAINING_REMOTE_DIR=/tmp/night_collect/feeding

# ── Shared ────────────────────────────────────────────────────
# Pet display names (shown in album UI)
# PET_NAME_MIKE=ミケ
# PET_NAME_CHATORA=チャトラ
