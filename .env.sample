# Smart Pet Camera — Environment Configuration
# Copy to .env and fill in your values:  cp .env.sample .env
#
# This file is used by both devices:
#   rdk-x5:      /app/smart-pet-camera/.env
#   ai-pyramid:  /app/smart-pet-camera/src/ai-pyramid/.env

# ── Device Discovery ─────────────────────────────────────────
# Full URLs (scheme + host + port)
# PET_CAMERA_HOST=https://your-camera-host.your-tenant.ts.net:8083
# PET_ALBUM_HOST=http://localhost:8082

# ── Pet Camera (rdk-x5) ──────────────────────────────────────
# TLS certificates (Tailscale: sudo tailscale cert <hostname>)
# PET_CAMERA_TLS_CERT=/path/to/camera-host.crt
# PET_CAMERA_TLS_KEY=/path/to/camera-host.key

# Additional ports
# PET_CAMERA_STREAMING_PORT=8081
# PET_CAMERA_METRICS_PORT=9090

# Log level: debug / info / warn / error
# PET_CAMERA_LOG_LEVEL=info

# YOLO detector
# PET_CAMERA_YOLO_MODEL=v11n
# PET_CAMERA_YOLO_SCORE_THRESHOLD=0.6

# ── Pet Album (ai-pyramid) ───────────────────────────────────
# TLS certificates for album server
# PET_ALBUM_TLS_CERT=/path/to/album-host.crt
# PET_ALBUM_TLS_KEY=/path/to/album-host.key

# Remote photos directory for rsync (default shown)
# PET_ALBUM_PHOTOS_DIR=/app/smart-pet-camera/src/ai-pyramid/data/photos

# VLM (axllm) endpoint
# PET_ALBUM_VLM_URL=http://localhost:8000
# PET_ALBUM_VLM_MODEL=AXERA-TECH/Qwen3-VL-2B-Instruct-GPTQ-Int4-C256-P3584-CTX4095

# ── Shared ────────────────────────────────────────────────────
# Pet display names (shown in album UI)
# PET_NAME_MIKE=ミケ
# PET_NAME_CHATORA=チャトラ
