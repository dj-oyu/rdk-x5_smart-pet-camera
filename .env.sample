# Smart Pet Camera — Environment Configuration
# Copy to .env and fill in your values:  cp .env.sample .env

# ── Pet Camera (rdk-x5) ──────────────────────────────────────
# TLS certificates (Tailscale: sudo tailscale cert <hostname>)
# PET_CAMERA_TLS_CERT=/path/to/hostname.crt
# PET_CAMERA_TLS_KEY=/path/to/hostname.key

# Server ports (defaults shown)
# PET_CAMERA_MONITOR_PORT=8080
# PET_CAMERA_STREAMING_PORT=8081
# PET_CAMERA_METRICS_PORT=9090

# Log level: debug / info / warn / error
# PET_CAMERA_LOG_LEVEL=info

# YOLO detector
# PET_CAMERA_YOLO_MODEL=v11n
# PET_CAMERA_YOLO_SCORE_THRESHOLD=0.6

# ── Pet Album (ai-pyramid) ───────────────────────────────────
# Base URL for ingest API (comic detection metadata)
# PET_ALBUM_URL=https://your-album-host:8082

# SSH host for rsync comic sync
# PET_ALBUM_SSH_HOST=your-album-host

# Remote photos directory (default: /app/smart-pet-camera/src/ai-pyramid/data/photos)
# PET_ALBUM_PHOTOS_DIR=/app/smart-pet-camera/src/ai-pyramid/data/photos

# TLS certificates for album server
# PET_ALBUM_TLS_CERT=/path/to/album-hostname.crt
# PET_ALBUM_TLS_KEY=/path/to/album-hostname.key

# VLM (axllm) endpoint
# PET_ALBUM_VLM_URL=http://localhost:8000
# PET_ALBUM_VLM_MODEL=AXERA-TECH/Qwen3-VL-2B-Instruct-GPTQ-Int4-C256-P3584-CTX4095

# Pet display names (shown in UI)
# PET_NAME_MIKE=ミケ
# PET_NAME_CHATORA=チャトラ
